# API Keys (copy to .env and fill with real values)
AILABTOOLS_API_KEY=your_ailabtools_api_key_here
REPLICATE_API_TOKEN=your_replicate_api_token_here
MICROSOFT_FACE_API_KEY=your_microsoft_face_api_key_here

# API Endpoints
AILABTOOLS_BASE_URL=https://api.ailabtools.com
REPLICATE_BASE_URL=https://api.replicate.com/v1
MICROSOFT_FACE_ENDPOINT=https://westus.api.cognitive.microsoft.com/face/v1.0

# App Config
APP_NAME=Heartly AI
APP_VERSION=0.0.1
